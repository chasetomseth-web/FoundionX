generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum FunnelStepType {
  upsell
  downsell
  cross_sell
  order_bump

  @@map("funnel_step_type")
}

enum UpsellChargeStatus {
  pending
  succeeded
  failed
  declined

  @@map("upsell_charge_status")
}

enum UpsellSessionStatus {
  active
  completed
  expired

  @@map("upsell_session_status")
}

// ============================================================
// USER & AUTH
// ============================================================

model Organization {
  id                   String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                 String
  slug                 String               @unique
  plan                 String               @default("starter")
  status               String               @default("active")
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  trialEndsAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  users                UserOrganization[]
  stores               Store[]
  apiKeys              ApiKey[]
  webhookEvents        WebhookEvent[]
  backgroundJobs       BackgroundJob[]
  notifications        Notification[]
  featureFlags         FeatureFlag[]
  supportTickets       SupportTicket[]
  auditLogs            AuditLog[]
  stripeReconciliationLogs StripeReconciliationLog[]
  sites                Site[]
  domains              Domain[]

  @@index([slug])
}

// ============================================================
// SITES & DOMAINS (Custom Domain Hosting)
// ============================================================

model Site {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId String
  name          String
  slug          String
  htmlContent   String   @db.Text
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  domains      Domain[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Domain {
  id                String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId    String
  siteId            String
  hostname          String    @unique
  vercelDomainId    String?
  verificationState String    @default("pending")
  sslState          String    @default("pending")
  verificationTxt   String?
  lastCheckedAt     DateTime?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  site         Site         @relation(fields: [siteId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([organizationId])
  @@index([siteId])
}

model User {
  id                 String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  email              String             @unique
  name               String?
  passwordHash       String?
  avatarUrl          String?
  emailVerified      Boolean            @default(false)
  mfaEnabled         Boolean            @default(false)
  mfaSecret          String?
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organizations      UserOrganization[]
  sessions           UserSession[]
  auditLogs          AuditLog[]
  notifications      Notification[]

  @@index([email])
}

model UserOrganization {
  id             String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId         String
  organizationId String
  role           String       @default("member")
  permissions    String[]     @default([])
  invitedAt      DateTime?
  joinedAt       DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model UserSession {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([token])
  @@index([userId])
}

model ApiKey {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId String
  name           String
  keyHash        String   @unique
  keyPrefix      String
  scopes         String[] @default([])
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([organizationId])
  @@index([keyHash])
}

// ============================================================
// AUDIT & LOGGING
// ============================================================

model AuditLog {
  id             String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId String
  userId         String?
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

// ============================================================
// STORE & MERCHANT PAGES
// ============================================================

model Store {
  id                 String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId     String
  name               String
  slug               String
  domain             String?
  customDomain       String?
  status             String   @default("active")
  currency           String   @default("USD")
  timezone           String   @default("UTC")
  goaffproStoreId    String?
  goaffproApiKey     String?
  sdkInjected        Boolean  @default(false)
  fromAddressName    String?
  fromAddressStreet  String?
  fromAddressCity    String?
  fromAddressState   String?
  fromAddressZip     String?
  fromAddressCountry String?
  fromAddressPhone   String?
  gtmId              String?
  facebookPixelId    String?
  tiktokPixelId      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization           Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  themes                 StoreTheme[]
  htmlTemplates          HtmlTemplate[]
  navigationMenus        NavigationMenu[]
  seoMetadata            SeoMetadata[]
  products               Product[]
  collections            Collection[]
  orders                 Order[]
  customers              Customer[]
  journeySteps           Json       @default("[]")
  subscriptions          Subscription[]
  affiliates             Affiliate[]
  emailCampaigns         EmailCampaign[]
  automationWorkflows    AutomationWorkflow[]
  customerSegments       CustomerSegment[]
  analyticsEvents        AnalyticsEvent[]
  conversionEvents       ConversionEvent[]
  funnelEvents           FunnelEvent[]
  merchantPages          MerchantPage[]
  offers                 Offer[]
  coupons                Coupon[]
  funnels                Funnel[]
  checkoutSessions       CheckoutSession[]
  uploadedAssets         UploadedAsset[]
  pages                  Page[]
  templates              Template[]
  globalComponents       GlobalComponent[]
  forms                  Form[]
  globalData             GlobalData?
  customVariables        CustomVariable[]
  funnelAnalyticsEvents  FunnelAnalyticsEvent[]
  siteComponents         SiteComponent[]
  siteVariables          SiteVariable[]
}

model SiteComponent {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId   String
  name      String
  slug      String
  type      String   @default("custom")
  html      String   @default("")
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([storeId, slug])
  @@index([storeId])
}

model SiteVariable {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId   String
  key       String
  value     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([storeId, key])
  @@index([storeId])
}

model StoreTheme {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId   String
  name      String
  isActive  Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model HtmlTemplate {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId        String
  name           String
  slug           String
  type           String   @default("page")
  rawHtml        String
  sanitizedHtml  String
  compiledHtml   String?
  cssContent     String?
  jsContent      String?
  bindings       Json     @default("[]")
  status         String   @default("draft")
  isDefault      Boolean  @default(false)
  seoTitle       String?
  seoDescription String?
  uploadedAt     DateTime @default(now())
  publishedAt    DateTime?
  updatedAt      DateTime @updatedAt

  store  Store           @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  blocks TemplateBlock[]
}

model TemplateBlock {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  templateId  String
  name        String
  type        String
  htmlContent String
  cssContent  String?
  bindings    Json     @default("[]")
  sortOrder   Int      @default(0)
  isReusable  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template HtmlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model UploadedAsset {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId      String
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  cdnUrl       String?
  altText      String?
  folder       String?
  createdAt    DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model NavigationMenu {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId   String
  name      String
  handle    String
  items     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model SeoMetadata {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId       String
  resourceType  String
  resourceId    String
  title         String?
  description   String?
  ogTitle       String?
  ogDescription String?
  ogImage       String?
  canonicalUrl  String?
  noIndex       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model MerchantPage {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId     String
  name        String
  slug        String
  type        String    @default("custom") @map("pageType")
  html        String    @default("")
  css         String    @default("")
  js          String    @default("")
  seoTitle    String?
  seoDesc     String?
  isCore      Boolean   @default(false)
  isTemplate  Boolean   @default(false)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  visibility  String    @default("public")
  status      String    @default("draft")
  metadata    Json      @default("{}")
  settings    Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  blocks       MerchantPageBlock[]
  publishedPage PublishedPage?

  @@unique([storeId, slug])
  @@index([storeId])
  @@map("MerchantPage")
}

model MerchantPageBlock {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  pageId    String
  parentId  String?
  order     Int      @default(0)
  type      String
  props     Json     @default("{}")
  style     Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page   MerchantPage      @relation(fields: [pageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  parent MerchantPageBlock? @relation("MerchantPageBlockParent", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  children MerchantPageBlock[] @relation("MerchantPageBlockParent")

  @@index([pageId])
  @@index([parentId])
}

model PublishedPage {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  merchantPageId String  @unique
  slug          String   @unique
  html          String
  css           String?
  metadata      Json?
  publishedAt   DateTime @default(now())

  merchantPage MerchantPage @relation(fields: [merchantPageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([slug])
}

// ============================================================
// PRODUCTS
// ============================================================

model Product {
  id               String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId          String
  name             String
  slug             String
  sku              String?
  description      String?
  price            Decimal  @db.Decimal(10, 2)
  compareAtPrice   Decimal? @db.Decimal(10, 2)
  costPrice        Decimal? @db.Decimal(10, 2)
  type             String   @default("physical")
  status           String   @default("draft")
  taxable          Boolean  @default(true)
  taxCode          String?
  weight           Decimal? @db.Decimal(8, 2)
  weightUnit       String?  @default("lb")
  hasUpsell        Boolean  @default(false)
  hasOrderBump     Boolean  @default(false)
  upsellProductId  String?
  orderBumpProductId String?
  stripeProductId  String?
  stripePriceId    String?
  metadata         Json?
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  variants     ProductVariant[]
  images       ProductImage[]
  files        ProductFile[]
  inventory    Inventory[]
  tags         ProductTag[]
  collections  ProductCollection[]
  offers       Offer[]
  orderItems   OrderItem[]
  funnelProducts FunnelProduct[]
}

model ProductVariant {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  productId       String
  name            String
  sku             String?
  price           Decimal  @db.Decimal(10, 2)
  compareAtPrice  Decimal? @db.Decimal(10, 2)
  inventory       Int      @default(0)
  options         Json     @default("{}")
  stripeProductId String?
  stripePriceId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model ProductImage {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  productId String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model ProductFile {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  productId    String
  name         String
  url          String
  path         String?
  size         Int
  contentType  String
  createdAt    DateTime @default(now())

  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([productId])
}

model FunnelProduct {
  id         String                      @id @default(dbgenerated("(gen_random_uuid())::text"))
  funnelId   String                      @db.Uuid
  productId  String
  sortOrder  Int                         @default(0)
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  funnel     upsell_funnels              @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  product    Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([funnelId, productId])
  @@index([funnelId])
  @@index([productId])
}

model Inventory {
  id             String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  productId      String
  variantId      String?
  quantity       Int     @default(0)
  reserved       Int     @default(0)
  available      Int     @default(0)
  lowStockAt     Int     @default(5)
  trackInventory Boolean @default(true)
  allowBackorder Boolean @default(false)
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Collection {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId     String
  name        String
  slug        String
  description String?
  imageUrl    String?
  status      String   @default("active")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store      Store               @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  products   ProductCollection[]
}

model ProductCollection {
  productId    String
  collectionId String
  sortOrder    Int      @default(0)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([productId, collectionId])
}

model ProductTag {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  productId String
  tag       String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

// ============================================================
// ORDERS & FULFILLMENT
// ============================================================

model Order {
  id                      String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId                 String
  customerId              String?
  orderNumber             String
  status                  String          @default("pending")
  paymentStatus           String          @default("pending")
  fulfillmentStatus       String          @default("unfulfilled")
  currency                String          @default("USD")
  subtotal                Decimal         @db.Decimal(10, 2)
  discountTotal           Decimal         @default(0) @db.Decimal(10, 2)
  shippingTotal           Decimal         @default(0) @db.Decimal(10, 2)
  taxTotal                Decimal         @default(0) @db.Decimal(10, 2)
  total                   Decimal         @db.Decimal(10, 2)
  refundedAmount          Decimal         @default(0) @db.Decimal(10, 2)
  couponCode              String?
  discountPercent         Decimal?        @db.Decimal(5, 2)
  affiliateId             String?
  affiliateCode           String?
  isSubscriptionOrder     Boolean         @default(false)
  subscriptionId          String?
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?
  stripeCustomerId        String?
  stripeInvoiceId         String?
  ipAddress               String?
  userAgent               String?
  notes                   String?
  metadata                Json?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items        OrderItem[]
  fulfillments Fulfillment[]
  shipments    Shipment[]
  refunds      Refund[]
  transactions Transaction[]
  taxRecords   TaxRecord[]
  checkoutSessions CheckoutSession[]
}

model OrderItem {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId     String
  productId   String?
  variantId   String?
  name        String
  sku         String?
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  isUpsell    Boolean  @default(false)
  isOrderBump Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model Fulfillment {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId     String
  status      String   @default("pending")
  notes       String?
  fulfilledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Refund {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId        String
  amount         Decimal  @db.Decimal(10, 2)
  reason         String?
  status         String   @default("pending")
  stripeRefundId String?
  processedAt    DateTime?
  createdAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Transaction {
  id                      String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId                 String
  type                    String
  status                  String
  amount                  Decimal  @db.Decimal(10, 2)
  currency                String   @default("USD")
  stripeTransactionId     String?
  stripePaymentIntentId   String?
  stripeChargeId          String?
  failureCode             String?
  failureMessage          String?
  metadata                Json?
  createdAt               DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model TaxRecord {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId      String
  taxCode      String?
  rate         Decimal  @db.Decimal(5, 4)
  amount       Decimal  @db.Decimal(10, 2)
  jurisdiction String?
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Shipment {
  id                 String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId            String
  carrier            String?
  trackingNumber     String?
  trackingUrl        String?
  status             String          @default("pending")
  shippedAt          DateTime?       @db.Timestamptz(6)
  deliveredAt        DateTime?       @db.Timestamptz(6)
  easypostShipmentId String?
  easypostTrackerId  String?
  labelUrl           String?
  service            String?
  rateAmount         Decimal?        @db.Decimal(10, 2)
  labelCreatedAt     DateTime?       @db.Timestamptz(6)
  createdAt          DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime        @default(now()) @updatedAt @db.Timestamptz(6)

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  trackingEvents TrackingEvent[]

  @@index([orderId])
  @@index([easypostShipmentId])
  @@index([trackingNumber])
}

model TrackingEvent {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  shipmentId      String
  easypostEventId String?
  status          String
  message         String?
  location        String?
  carrier         String?
  eventTime       DateTime? @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([shipmentId])
  @@index([easypostEventId])
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id                String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  storeId           String
  email             String
  name              String?
  firstName         String?
  lastName          String?
  phone             String?
  country           String?
  status            String          @default("active")
  tags              String[]        @default([])
  notes             String?
  stripeCustomerId  String?
  totalSpent        Decimal         @default(0) @db.Decimal(10, 2)
  totalOrders       Int             @default(0)
  avgOrderValue     Decimal         @default(0) @db.Decimal(10, 2)
  ltv               Decimal         @default(0) @db.Decimal(10, 2)
  lastOrderAt       DateTime?
  acceptsMarketing  Boolean         @default(false)
  brevoContactId    String?
  passwordHash      String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  store           Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  addresses       CustomerAddress[]
  paymentMethods  CustomerPaymentMethod[]
  sessions        CustomerSession[]
  orders          Order[]
  @@unique([storeId, email])
  subscriptions   Subscription[]
}

model CustomerAddress {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  customerId String
  type       String   @default("shipping")
  isDefault  Boolean  @default(false)
  firstName  String?
  lastName   String?
  company    String?
  address1   String
