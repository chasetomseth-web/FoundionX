  organizationId  String?
  storeId         String?
  runAt           DateTime @default(now())
  status          String
  ordersChecked   Int      @default(0)
  ordersMismatched Int     @default(0)
  ordersFixed     Int      @default(0)
  subsChecked     Int      @default(0)
  subsMismatched  Int      @default(0)
  subsFixed       Int      @default(0)
  errors          Json?
  durationMs      Int?
  triggeredBy     String   @default("scheduler")
  createdAt       DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
}

// ============================================================
// SUPPORT DESK
// ============================================================

model SupportTicket {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId String
  customerName   String?
  customerEmail  String
  subject        String
  status         String   @default("open")
  createdAt      DateTime @default(now()) @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  messages     SupportMessage[]
  tags         SupportTag[]

  @@index([organizationId])
  @@index([customerEmail])
  @@index([status])
  @@index([updatedAt])
}

model SupportMessage {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  ticketId   String
  senderType String   // customer | agent
  senderEmail String?
  body       String
  createdAt  DateTime @default(now()) @db.Timestamptz()

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model SupportTag {
  id       String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  ticketId String
  tag      String
  createdAt DateTime @default(now()) @db.Timestamptz()

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, tag])
  @@index([ticketId])
}

// ============================================================
// SNAKE_CASE MODELS (created by final migration)
// ============================================================

model coupons {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String   @unique
  type           String
  value          Decimal  @default(0) @db.Decimal(10, 2)
  usage_count    Int      @default(0)
  usage_limit    Int?
  minimum_order  Decimal? @db.Decimal(10, 2)
  expires_at     DateTime? @db.Timestamptz(6)
  status         String   @default("active")
  revenue        Decimal  @default(0) @db.Decimal(12, 2)
  stripe_coupon_id String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([code], map: "idx_coupons_code")
  @@index([status], map: "idx_coupons_status")
}

model integration_settings {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider    String   @unique
  credentials Json     @default("{}")
  connected   Boolean  @default(false)
  details     String?
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([provider], map: "idx_integration_settings_provider")
}

model store_credentials {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  store_id               String   @unique
  stripe_secret_key      String?
  stripe_publishable_key String?
  stripe_webhook_secret  String?
  resend_api_key         String?
  updated_at             DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  created_at             DateTime @default(now()) @db.Timestamptz(6)

  @@index([store_id], map: "idx_store_credentials_store_id")
}

model funnel_steps {
  id                      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  funnel_id               String           @db.Uuid
  step_order              Int
  step_type               FunnelStepType   @default(upsell)
  name                    String
  price_cents             Int              @default(0)
  currency                String           @default("usd")
  html_content            String?
  decline_next_step_order Int?
  accept_next_step_order  Int?
  stripe_price_id         String?
  created_at              DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?        @default(now()) @updatedAt @db.Timestamptz(6)

  upsell_funnels upsell_funnels? @relation(fields: [funnel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  upsell_charges upsell_charges[]

  @@index([funnel_id], map: "idx_funnel_steps_funnel_id")
  @@index([funnel_id, step_order], map: "idx_funnel_steps_order")
}

model upsell_funnels {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  description       String?
  is_active         Boolean?        @default(true)
  trigger_product_id String?
  created_at        DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?       @default(now()) @updatedAt @db.Timestamptz(6)

  funnel_steps  funnel_steps[]
  upsell_sessions upsell_sessions[]
  funnel_products FunnelProduct[]
}

model upsell_charges {
  id                       String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  upsell_session_id        String                @db.Uuid
  funnel_step_id           String                @db.Uuid
  stripe_payment_intent_id String?
  stripe_customer_id       String
  stripe_payment_method_id String
  amount_cents             Int
  currency                 String                @default("usd")
  status                   UpsellChargeStatus?   @default(pending)
  error_message            String?
  created_at               DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?             @default(now()) @updatedAt @db.Timestamptz(6)

  funnel_steps    funnel_steps    @relation(fields: [funnel_step_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  upsell_sessions upsell_sessions @relation(fields: [upsell_session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([upsell_session_id], map: "idx_upsell_charges_session")
}

model upsell_sessions {
  id                         String               @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Uuid
  stripe_checkout_session_id String
  stripe_customer_id         String
  stripe_payment_method_id   String
  funnel_id                  String?              @db.Uuid
  current_step_order         Int?                 @default(1)
  status                     UpsellSessionStatus? @default(active)
  accepted_step_orders       Int[]                @default([])
  declined_step_orders       Int[]                @default([])
  customer_email             String?
  original_order_amount      Int?
  total_upsell_revenue       Int?                 @default(0)
  created_at                 DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime?            @default(now()) @updatedAt @db.Timestamptz(6)
  expires_at                 DateTime?            @default(dbgenerated("(CURRENT_TIMESTAMP + '02:00:00'::interval)")) @db.Timestamptz(6)

  upsell_charges upsell_charges[]
  upsell_funnels upsell_funnels? @relation(fields: [funnel_id], references: [id], onUpdate: NoAction)

  @@index([stripe_checkout_session_id], map: "idx_upsell_sessions_checkout")
  @@index([stripe_customer_id], map: "idx_upsell_sessions_customer")
}

enum SaleseekerJobStatus {
  pending
  running
  done
  failed

  @@map("saleseeker_job_status")
}

model SaleseekerBusiness {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Uuid
  name      String
  website   String?
  phone     String?
  address   String?
  city      String?
  state     String?
  country   String?
  niche     String
  placeId   String?  @map("place_id")
  rating    Float?
  reviews   Int?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  leads SaleseekerLead[]

  @@unique([placeId], map: "saleseeker_businesses_place_id_key")
  @@index([niche, city, state, country], map: "idx_saleseeker_businesses_geo_niche")
  @@map("saleseeker_businesses")
}

model SaleseekerLead {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  email      String
  phone      String?
  ownerName  String?  @map("owner_name")
  sourceUrl  String?  @map("source_url")
  tags       String[] @default([])
  campaignId String?  @map("campaign_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  business  SaleseekerBusiness   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign  SaleseekerCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([businessId, email], map: "saleseeker_leads_business_email_key")
  @@index([campaignId], map: "idx_saleseeker_leads_campaign")
  @@map("saleseeker_leads")
}

model SaleseekerCampaign {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Uuid
  name      String
  niche     String?
  tags      String[] @default([])
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  leads SaleseekerLead[]

  @@index([niche], map: "idx_saleseeker_campaigns_niche")
  @@map("saleseeker_campaigns")
}

model SaleseekerJob {
  id        String            @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Uuid
  status    SaleseekerJobStatus @default(pending)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status, createdAt], map: "idx_saleseeker_jobs_status_created")
  @@map("saleseeker_jobs")
}
