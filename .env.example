# Wiastro Environment Variables
# Copy this file to .env and fill in your actual values

# ==================== REQUIRED ====================

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here

# Supabase (Auth & Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# PostgreSQL Database
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:port/database"

# Redis (Optional - for caching and queues)
REDIS_URL=redis://localhost:6379

# Resend (Transactional Email)
RESEND_API_KEY=re_your-resend-api-key-here
EMAIL_FROM=noreply@yourdomain.com

# Cron Security (for scheduled jobs)
CRON_SECRET=your-cron-secret-here

# Application URL
NEXT_PUBLIC_SITE_URL=https://wiastro.com
NEXT_PUBLIC_APP_URL=https://wiastro.com

# Vercel (Custom Domain Hosting)
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ==================== OPTIONAL ====================

# Brevo (Marketing Emails)
BREVO_API_KEY=xkeysib-your-brevo-api-key-here
BREVO_WEBHOOK_SECRET=your-brevo-webhook-secret-here
BREVO_TEMPLATE_ORDER_CONFIRMATION=0
BREVO_TEMPLATE_FAILED_PAYMENT=0
BREVO_TEMPLATE_SUBSCRIPTION_RENEWAL=0
BREVO_TEMPLATE_AFFILIATE_WELCOME=0
BREVO_TEMPLATE_ABANDONED_CART=0

# Shippo or EasyPost (Shipping Labels)
SHIPPO_API_KEY=shippo_test_your-shippo-api-key-here
EASYPOST_API_KEY=EZTEST_your-easypost-api-key-here

# GoAffPro (External Affiliate Platform - if used)
GOAFFPRO_ACCESS_TOKEN=your-goaffpro-access-token
GOAFFPRO_PUBLIC_TOKEN=your-goaffpro-public-token
GOAFFPRO_WEBHOOK_SECRET=your-goaffpro-webhook-secret

# SalesBlink (Cold Outreach)
SALESBLINK_API_KEY=your-salesblink-api-key-here

# AI Features
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
PERPLEXITY_API_KEY=pplx-your-perplexity-api-key-here

# Google Analytics & AdSense
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# Credentials Encryption (for database-stored API keys)
CREDENTIALS_ENCRYPTION_KEY=your-32-character-encryption-key-here-change-in-production

# Alert Email (for system notifications)
ALERT_EMAIL=alerts@yourdomain.com
MERCHANT_ALERT_EMAIL=admin@yourdomain.com
FROM_NAME=MerchantOS

# Internal API Security
INTERNAL_API_SECRET=your-internal-api-secret-here

# Redis Rate Limiting
RATE_LIMIT_BURST=100
RATE_LIMIT_RPM=60

# Resend Webhooks
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret-here
